---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PostMeta from "../components/PostMeta.astro";

const posts = (await getCollection("blog")).toSorted(
	(a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0),
);
---

<Layout title="Blog" description="A list of all the blog posts I've written.">
	<div class="flex flex-col gap-4 sm:gap-6">
		{posts.map((post) => (
				<article class="border-2 border-gray-500 dark:border-gray-300 py-5 px-6 space-y-1 text-black dark:text-slate-100">
					<h1 class="font-medium text-xl">
						<a href={`/blog/${post.id}`} class="hover:underline">
							{post.data.title}
						</a>
					</h1>
					<p>{post.data.description}</p>
					<PostMeta
						pubDate={post.data.pubDate}
						categories={post.data.categories}
					/>
				</article>
			))}
	</div>
</Layout>
